{
  "mcpServers": {
    "echo-search": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/echo-search/start.sh",
      "args": []
    },
    "figma-to-react": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/figma-to-react/start.sh",
      "args": []
    },
    "agent-search": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/agent-search/start.sh",
      "args": []
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@2.1.3"],
      "_supply_chain_note": "Pinned to exact version 2.1.3. Verify with `npm pack` if stricter supply-chain controls are required."
    },
    "figma-context": {
      "type": "stdio",
      "command": "sh",
      "args": ["-c", "npx -y figma-developer-mcp@0.8.0 --figma-api-key=$FIGMA_TOKEN --stdio"],
      "env": { "FIGMA_TOKEN": "${FIGMA_TOKEN}" }
    }
  }
}
